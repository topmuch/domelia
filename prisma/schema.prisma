generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String            @id @default(cuid())
  email         String            @unique
  passwordHash  String
  name          String?
  role          String            @default("locataire")
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  colocations   ColocListing[]
  listings      LandlordListing[]
  reportActions Report[]          @relation("ReportHandler")
  reports       Report[]          @relation("ReportReporter")
  services      ServiceAd[]
  tenantProfile TenantProfile?
  professionalAccount ProfessionalAccount?
  favorites     Favorite[]
  notifications Notification[]
  sentMessages  Message[]         @relation("SentMessages")
  conversations Conversation[]
  payments     Payment[]
  unlockedContacts UnlockedContact[]
  serviceRequestsMade ServiceRequest[] @relation("ServiceRequester")
  proReviews    ServiceReview[]   @relation("ProReviewer")

  @@map("users")
}

model TenantProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  firstName    String
  lastName     String?
  city         String
  budget       Int
  housingType  String?
  jobStatus    String
  hasGuarantor Boolean  @default(false)
  urgency      String   @default("flexible")
  description  String?
  phone        String?
  isActive     Boolean  @default(true)
  views        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tenant_profiles")
}

model LandlordListing {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String?
  location    String
  address     String?
  price       Int
  surface     Int?
  rooms       Int?
  photos      String?
  isActive    Boolean  @default(true)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  latitude    Float?
  longitude   Float?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("landlord_listings")
}

model ColocListing {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String?
  location    String
  address     String?
  price       Int
  surface     Int?
  photos      String?
  latitude    Float?
  longitude   Float?
  isActive    Boolean  @default(true)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("coloc_listings")
}

model ServiceAd {
  id          String         @id @default(cuid())
  proId       String
  company     String?
  siret       String?
  category    String
  title       String
  description String?
  price       Int?
  zone        String?
  photo       String?
  isVerified  Boolean        @default(false)
  isActive    Boolean        @default(true)
  views       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [proId], references: [id], onDelete: Cascade)
  reviews     ServiceReview[]

  @@map("service_ads")
}

model ServiceReview {
  id        String   @id @default(cuid())
  serviceId String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  service   ServiceAd @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user      User     @relation("ProReviewer", fields: [userId], references: [id], onDelete: Cascade)

  @@map("service_reviews")
}

model Report {
  id           String   @id @default(cuid())
  reporterId   String
  targetType   String
  targetId     String
  reason       String
  description  String?
  status       String   @default("nouveau")
  handlerId    String?
  internalNote String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  handler      User?    @relation("ReportHandler", fields: [handlerId], references: [id])
  reporter     User     @relation("ReportReporter", fields: [reporterId], references: [id])

  @@map("reports")
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String?
  targetId   String?
  details    String?
  createdAt  DateTime @default(now())

  @@map("admin_logs")
}

model Conversation {
  id           String    @id @default(cuid())
  participants String    // JSON array of userIds
  listingId    String?
  listingType  String?   // "locataire", "logement", "coloc", "service"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]
  users        User[]

  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  targetType String   // "locataire", "logement", "coloc", "service"
  targetId   String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@map("favorites")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "message", "favorite", "report", "system"
  title     String
  content   String
  link      String?  // Lien optionnel
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// Paiements pour déverrouillage de contacts
model Payment {
  id            String   @id @default(cuid())
  userId        String   // Propriétaire qui paie
  amount        Float    // Montant en euros
  currency      String   @default("EUR")
  status        String   @default("pending") // "pending", "succeeded", "failed"
  type          String   @default("contact") // Type de paiement
  targetId      String   // ID du locataire contacté
  paypalOrderId String? // ID de la commande PayPal
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// Contacts déverrouillés (après paiement)
model UnlockedContact {
  id          String   @id @default(cuid())
  landlordId  String   // ID du propriétaire
  tenantId    String   // ID du profil locataire
  paymentId   String   // Référence au paiement
  unlockedAt  DateTime @default(now())
  user        User     @relation(fields: [landlordId], references: [id], onDelete: Cascade)

  @@unique([landlordId, tenantId]) // Un propriétaire ne peut déverrouiller qu'une fois chaque locataire
  @@map("unlocked_contacts")
}

// Paramètres de l'application
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// Comptes professionnels (déménageurs, garde-meubles, assureurs, etc.)
model ProfessionalAccount {
  id                String           @id @default(cuid())
  userId            String           @unique
  companyName       String           // Raison sociale
  siret             String           // SIRET chiffré
  siretHash         String           @unique // Hash pour vérification
  phone             String?
  zone              String           // Zone d'intervention (ex: "Paris", "France entière")
  logo              String?          // URL du logo
  description       String?          // Description de l'entreprise
  isVerified        Boolean          @default(false) // SIRET vérifié
  isApproved        Boolean          @default(false) // Approuvé par admin
  subscriptionType  String           @default("none") // "none", "per_ad", "monthly"
  subscriptionEnd   DateTime?        // Date de fin d'abonnement
  partnerBadge      Boolean          @default(false) // Badge "Partenaire officiel"
  totalViews        Int              @default(0)
  totalRequests     Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  services          ProService[]
  requests          ServiceRequest[] @relation("ProRequests")
  subscriptionPayments ProSubscriptionPayment[]

  @@map("professional_accounts")
}

// Services proposés par les professionnels
model ProService {
  id             String          @id @default(cuid())
  proId          String
  category       String          // "demenagement", "garde_meubles", "assurance", "nettoyage", "autre"
  title          String
  description    String?
  price          Int?            // Prix en centimes (null = sur devis)
  priceType      String          @default("fixed") // "fixed", "from", "on_quote"
  photos         String?         // JSON array of URLs
  zone           String?         // Zone spécifique si différente du profil
  isActive       Boolean         @default(true)
  isPaid         Boolean         @default(false) // Paiement effectué (5€ ou abonnement)
  paymentId      String?         // Référence au paiement
  views          Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  pro            ProfessionalAccount @relation(fields: [proId], references: [id], onDelete: Cascade)
  requests       ServiceRequest[]

  @@map("pro_services")
}

// Demandes de contact vers les professionnels
model ServiceRequest {
  id           String   @id @default(cuid())
  serviceId    String
  proId        String
  requesterId  String
  requesterName    String
  requesterEmail   String
  requesterPhone   String?
  message      String
  status       String   @default("nouveau") // "nouveau", "en_cours", "termine", "archive"
  proNotes     String?  // Notes internes du pro
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  service      ProService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  pro          ProfessionalAccount @relation("ProRequests", fields: [proId], references: [id], onDelete: Cascade)
  requester    User     @relation("ServiceRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  @@map("service_requests")
}

// Paiements d'abonnements professionnels
model ProSubscriptionPayment {
  id            String   @id @default(cuid())
  proId         String
  amount        Float    // Montant en euros
  type          String   // "per_ad", "monthly"
  status        String   @default("pending") // "pending", "succeeded", "failed"
  paypalOrderId String?
  startDate     DateTime @default(now())
  endDate       DateTime? // Pour les abonnements mensuels
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  pro           ProfessionalAccount @relation(fields: [proId], references: [id], onDelete: Cascade)

  @@map("pro_subscription_payments")
}
